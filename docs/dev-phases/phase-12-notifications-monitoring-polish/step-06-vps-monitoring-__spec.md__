# Step 6: VPS Monitoring & Alerts

**Phase:** 12 -- Notifications, Monitoring & Polish
**Step:** 6 of 6
**Type:** Backend implementation + API
**Depends on:** Steps 1-4 (notification system for sending alerts), Phase 1 (VPS with Docker), Phase 5 (port allocations table)
**Blocks:** None (final step of final phase)

---

## Objective

Implement a VPS resource monitor that tracks disk usage, memory usage, running container count, and port allocations. Expose the stats via an API endpoint for the dashboard settings page. Set up threshold-based alerting that sends notifications when disk or memory usage exceeds safe levels. Provide a `/api/health` endpoint for external monitoring services.

---

## File to Create: `packages/core/src/monitoring/vps-monitor.ts`

### Function: `getDiskUsage(): Promise<DiskUsage>`

Parse the output of `df -h /` to get disk usage stats.

```typescript
import { exec } from "node:child_process";
import { promisify } from "node:util";

const execAsync = promisify(exec);

export interface DiskUsage {
  totalGb: number;
  usedGb: number;
  availableGb: number;
  usagePercent: number;
}

export async function getDiskUsage(): Promise<DiskUsage> {
  const { stdout } = await execAsync("df -BG / | tail -1", { timeout: 5000 });
  // Example output: "/dev/sda1    80G  34G  43G  45% /"
  const parts = stdout.trim().split(/\s+/);

  return {
    totalGb: parseFloat(parts[1]),      // "80G" -> 80
    usedGb: parseFloat(parts[2]),       // "34G" -> 34
    availableGb: parseFloat(parts[3]),  // "43G" -> 43
    usagePercent: parseInt(parts[4]),   // "45%" -> 45
  };
}
```

### Function: `getMemoryUsage(): Promise<MemoryUsage>`

Parse the output of `free -m` to get memory usage stats.

```typescript
export interface MemoryUsage {
  totalMb: number;
  usedMb: number;
  availableMb: number;
  usagePercent: number;
}

export async function getMemoryUsage(): Promise<MemoryUsage> {
  const { stdout } = await execAsync("free -m | grep Mem:", { timeout: 5000 });
  // Example output: "Mem:      8192   2560   3072    256   2560   5376"
  const parts = stdout.trim().split(/\s+/);

  const totalMb = parseInt(parts[1]);
  const usedMb = parseInt(parts[2]);
  const availableMb = parseInt(parts[6]);  // "available" column

  return {
    totalMb,
    usedMb,
    availableMb,
    usagePercent: Math.round((usedMb / totalMb) * 100),
  };
}
```

### Function: `getContainerStats(): Promise<ContainerStats>`

Use Docker CLI to count running and stopped containers.

```typescript
export interface ContainerStats {
  running: number;
  stopped: number;
  total: number;
}

export async function getContainerStats(): Promise<ContainerStats> {
  const { stdout: runningOutput } = await execAsync(
    'docker ps -q --filter "status=running" | wc -l',
    { timeout: 5000 },
  );
  const { stdout: allOutput } = await execAsync(
    "docker ps -aq | wc -l",
    { timeout: 5000 },
  );

  const running = parseInt(runningOutput.trim());
  const total = parseInt(allOutput.trim());

  return {
    running,
    stopped: total - running,
    total,
  };
}
```

### Function: `getPortUsage(db: Database): Promise<PortUsage>`

Query the `port_allocations` table for current port allocation stats.

```typescript
import { portAllocations, deployments } from "@gblockparty/shared/db/schema";
import { sql, eq } from "drizzle-orm";
import { PORT_RANGES } from "@gblockparty/shared/constants";

export interface PortUsage {
  allocated: number;
  productionUsed: number;
  previewUsed: number;
  available: number;
}

export async function getPortUsage(db: Database): Promise<PortUsage> {
  const allocations = await db.select().from(portAllocations);

  let productionUsed = 0;
  let previewUsed = 0;

  for (const alloc of allocations) {
    if (alloc.port >= PORT_RANGES.PRODUCTION_MIN && alloc.port <= PORT_RANGES.PRODUCTION_MAX) {
      productionUsed++;
    } else if (alloc.port >= PORT_RANGES.PREVIEW_MIN && alloc.port <= PORT_RANGES.PREVIEW_MAX) {
      previewUsed++;
    }
  }

  const totalAvailable =
    (PORT_RANGES.PRODUCTION_MAX - PORT_RANGES.PRODUCTION_MIN + 1) +
    (PORT_RANGES.PREVIEW_MAX - PORT_RANGES.PREVIEW_MIN + 1);

  return {
    allocated: allocations.length,
    productionUsed,
    previewUsed,
    available: totalAvailable - allocations.length,
  };
}
```

### Function: `getVpsStats(db: Database): Promise<VpsStats>`

Aggregate all monitoring data into a single response.

```typescript
export interface VpsStats {
  disk: DiskUsage;
  memory: MemoryUsage;
  containers: ContainerStats;
  ports: PortUsage;
}

export async function getVpsStats(db: Database): Promise<VpsStats> {
  const [disk, memory, containers, ports] = await Promise.all([
    getDiskUsage().catch(() => ({ totalGb: 0, usedGb: 0, availableGb: 0, usagePercent: 0 })),
    getMemoryUsage().catch(() => ({ totalMb: 0, usedMb: 0, availableMb: 0, usagePercent: 0 })),
    getContainerStats().catch(() => ({ running: 0, stopped: 0, total: 0 })),
    getPortUsage(db),
  ]);

  return { disk, memory, containers, ports };
}
```

Note: Shell command failures (e.g., on macOS during development) return zeroed defaults. This is intentional -- the commands only work on the Linux VPS.

