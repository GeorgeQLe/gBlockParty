## API Route: `apps/dashboard/src/app/api/settings/vps-stats/route.ts`

```typescript
import { withAuth, jsonResponse } from "@/lib/api-helpers";
import { getVpsStats } from "@gblockparty/core/monitoring";
import { getDb } from "@gblockparty/shared/db";

// Simple in-memory cache to avoid running shell commands on every request
let cachedStats: VpsStats | null = null;
let lastFetchTime = 0;
const CACHE_TTL_MS = 10_000; // 10 seconds

export const GET = withAuth(async () => {
  const now = Date.now();
  if (cachedStats && now - lastFetchTime < CACHE_TTL_MS) {
    return jsonResponse(cachedStats);
  }

  const stats = await getVpsStats(getDb());
  cachedStats = stats;
  lastFetchTime = now;

  return jsonResponse(stats);
});
```

