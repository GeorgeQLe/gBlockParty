## Alert System

### Threshold Configuration

```typescript
const ALERT_THRESHOLDS = {
  DISK_USAGE_PERCENT: 80,
  MEMORY_USAGE_PERCENT: 90,
} as const;
```

### Alert Check Function

```typescript
export async function checkAndAlert(db: Database): Promise<void> {
  const stats = await getVpsStats(db);
  const alerts: string[] = [];

  if (stats.disk.usagePercent > ALERT_THRESHOLDS.DISK_USAGE_PERCENT) {
    alerts.push(
      `Disk usage is at ${stats.disk.usagePercent}% (${stats.disk.usedGb}GB / ${stats.disk.totalGb}GB). ` +
      `Consider running Docker image cleanup.`,
    );
  }

  if (stats.memory.usagePercent > ALERT_THRESHOLDS.MEMORY_USAGE_PERCENT) {
    alerts.push(
      `Memory usage is at ${stats.memory.usagePercent}% (${stats.memory.usedMb}MB / ${stats.memory.totalMb}MB). ` +
      `Consider stopping unused containers.`,
    );
  }

  if (alerts.length === 0) return;

  // Load notification settings and send alert
  const settings = await loadNotificationSettings(db);
  if (!settings) return;

  for (const alertMessage of alerts) {
    await notify(
      {
        slackWebhookUrl: settings.slackWebhookUrl,
        discordWebhookUrl: settings.discordWebhookUrl,
      },
      {
        projectName: "Platform Alert",
        deploymentType: "monitoring",
        status: "failed",
        errorMessage: alertMessage,
      },
    ).catch(err => {
      logger.error({ error: err }, "Failed to send VPS alert notification");
    });
  }
}
```

### Scheduling

Run the alert check on a periodic schedule:

```typescript
// In the platform startup (e.g., dashboard's instrumentation or a background worker)
const ALERT_CHECK_INTERVAL_MS = 5 * 60 * 1000; // 5 minutes
let lastAlertTime: Record<string, number> = {};
const ALERT_DEBOUNCE_MS = 60 * 60 * 1000; // 1 hour

setInterval(async () => {
  try {
    await checkAndAlert(getDb());
  } catch (error) {
    logger.error({ error }, "VPS alert check failed");
  }
}, ALERT_CHECK_INTERVAL_MS);
```

**Alert debounce:** Don't send the same alert type more than once per hour. Track the last alert timestamp per alert type (disk, memory) and skip if within the debounce window.

