## Testing

### Unit Tests

```typescript
describe("createOrUpdatePRComment", () => {
  it("creates a new comment when no existing bot comment", async () => {
    const mockOctokit = {
      issues: {
        listComments: vi.fn().mockResolvedValue({ data: [] }),
        createComment: vi.fn().mockResolvedValue({ data: { id: 1 } }),
      },
    };

    await createOrUpdatePRComment(
      mockOctokit as any, "owner", "repo", 42,
      "<!-- gblockparty-bot -->\n## Preview",
    );

    expect(mockOctokit.issues.createComment).toHaveBeenCalledWith({
      owner: "owner",
      repo: "repo",
      issue_number: 42,
      body: "<!-- gblockparty-bot -->\n## Preview",
    });
  });

  it("updates existing comment when bot comment found", async () => {
    const mockOctokit = {
      issues: {
        listComments: vi.fn().mockResolvedValue({
          data: [
            { id: 100, body: "some other comment" },
            { id: 200, body: "<!-- gblockparty-bot -->\n## Old Preview" },
          ],
        }),
        updateComment: vi.fn().mockResolvedValue({ data: { id: 200 } }),
      },
    };

    await createOrUpdatePRComment(
      mockOctokit as any, "owner", "repo", 42,
      "<!-- gblockparty-bot -->\n## Updated Preview",
    );

    expect(mockOctokit.issues.updateComment).toHaveBeenCalledWith({
      owner: "owner",
      repo: "repo",
      comment_id: 200,
      body: "<!-- gblockparty-bot -->\n## Updated Preview",
    });
  });

  it("does not throw on API error", async () => {
    const mockOctokit = {
      issues: {
        listComments: vi.fn().mockRejectedValue(new Error("API error")),
      },
    };

    // Should not throw
    await createOrUpdatePRComment(
      mockOctokit as any, "owner", "repo", 42, "body",
    );
  });
});

describe("formatDeploymentComment", () => {
  it("includes bot marker in output", () => {
    const result = formatDeploymentComment("ready", "https://preview.url", 5000);
    expect(result).toContain("<!-- gblockparty-bot -->");
  });

  it("includes URL when provided", () => {
    const result = formatDeploymentComment("ready", "https://preview.url", 5000);
    expect(result).toContain("https://preview.url");
  });

  it("omits URL when null", () => {
    const result = formatDeploymentComment("failed", null, null);
    expect(result).not.toContain("URL:");
  });

  it("formats build time in seconds", () => {
    const result = formatDeploymentComment("ready", "url", 34200);
    expect(result).toContain("34.2s");
  });
});
```

### Manual Verification

1. Open a PR on a connected repo
2. Verify a bot comment appears on the PR with:
   - Preview status
   - Preview URL (clickable)
   - Build time
3. Push a new commit to the PR
4. Verify the same comment is updated (not a new comment)
5. Verify the URL and build time reflect the latest deployment
6. Trigger a failing build
7. Verify the comment is updated to show failure status

