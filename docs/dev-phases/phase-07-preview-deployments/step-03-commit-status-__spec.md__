## Testing

### Unit Tests

```typescript
describe("setCommitStatus", () => {
  it("calls createCommitStatus with correct parameters", async () => {
    const mockOctokit = {
      repos: {
        createCommitStatus: vi.fn().mockResolvedValue({}),
      },
    };

    await setCommitStatus(
      mockOctokit as any,
      "owner", "repo", "abc1234567890",
      "success",
      { targetUrl: "https://pr-42--myapp.example.com", context: "gblockparty/preview" },
    );

    expect(mockOctokit.repos.createCommitStatus).toHaveBeenCalledWith({
      owner: "owner",
      repo: "repo",
      sha: "abc1234567890",
      state: "success",
      target_url: "https://pr-42--myapp.example.com",
      description: "Preview deployment ready",
      context: "gblockparty/preview",
    });
  });

  it("does not throw on GitHub API error", async () => {
    const mockOctokit = {
      repos: {
        createCommitStatus: vi.fn().mockRejectedValue(new Error("API error")),
      },
    };

    // Should not throw
    await setCommitStatus(mockOctokit as any, "owner", "repo", "sha", "pending");
  });

  it("truncates description to 140 characters", async () => {
    const mockOctokit = {
      repos: {
        createCommitStatus: vi.fn().mockResolvedValue({}),
      },
    };
    const longDescription = "A".repeat(200);

    await setCommitStatus(
      mockOctokit as any, "owner", "repo", "sha", "failure",
      { description: longDescription },
    );

    const call = mockOctokit.repos.createCommitStatus.mock.calls[0][0];
    expect(call.description.length).toBeLessThanOrEqual(140);
  });

  it("uses default description when none provided", async () => {
    const mockOctokit = {
      repos: {
        createCommitStatus: vi.fn().mockResolvedValue({}),
      },
    };

    await setCommitStatus(mockOctokit as any, "owner", "repo", "sha", "pending");

    const call = mockOctokit.repos.createCommitStatus.mock.calls[0][0];
    expect(call.description).toBe("Preview deployment building...");
  });
});
```

### Manual Verification

1. Push a commit to a PR on a connected repo
2. Check the commit on GitHub for the status check:
   - Initially shows as yellow dot (pending)
   - Changes to green checkmark (success) with "Details" link to preview URL
3. Trigger a failing build and verify the red X (failure) status appears

