## Implementation Plan

### Part A: Complete the Webhook API Route

**File:** `apps/dashboard/src/app/api/webhooks/github/route.ts`

```typescript
import { NextRequest, NextResponse } from "next/server";
import { verifySignature, handleWebhook } from "@gblockparty/core/github";
import { getDb } from "@gblockparty/shared/db";
import type { WebhookPayload } from "@gblockparty/shared/types";
import { createLogger } from "@gblockparty/shared/backend";

const logger = createLogger("webhook-route");

// Simple in-memory set for delivery ID deduplication
// In production, this could use Redis or a DB table for persistence across restarts
const processedDeliveries = new Set<string>();
const MAX_CACHED_DELIVERIES = 1000;

export async function POST(request: NextRequest) {
  const body = await request.text();
  const signature = request.headers.get("x-hub-signature-256") ?? "";
  const event = request.headers.get("x-github-event") ?? "";
  const deliveryId = request.headers.get("x-github-delivery") ?? "";

  const secret = process.env.GITHUB_APP_WEBHOOK_SECRET;
  if (!secret) {
    return NextResponse.json(
      { error: "Webhook secret not configured" },
      { status: 500 },
    );
  }

  // Verify HMAC signature
  if (!verifySignature(body, signature, secret)) {
    logger.warn({ deliveryId, event }, "Invalid webhook signature");
    return NextResponse.json({ error: "Invalid signature" }, { status: 401 });
  }

  // Deduplicate by delivery ID
  if (processedDeliveries.has(deliveryId)) {
    logger.info({ deliveryId, event }, "Duplicate delivery, skipping");
    return NextResponse.json({ received: true, duplicate: true });
  }

  // Track delivery ID (evict oldest if cache is full)
  if (processedDeliveries.size >= MAX_CACHED_DELIVERIES) {
    const oldest = processedDeliveries.values().next().value;
    processedDeliveries.delete(oldest);
  }
  processedDeliveries.add(deliveryId);

  // Parse payload
  let payload: WebhookPayload;
  try {
    payload = JSON.parse(body) as WebhookPayload;
  } catch {
    logger.error({ deliveryId }, "Failed to parse webhook payload");
    return NextResponse.json({ error: "Invalid JSON" }, { status: 400 });
  }

  // Process webhook asynchronously -- return 200 immediately
  // GitHub expects a response within 10 seconds
  const db = getDb();

  // Fire-and-forget: handle the webhook in the background
  handleWebhook({ db, payload, event, deliveryId }).catch((err) => {
    logger.error({ err, deliveryId, event }, "Webhook handler failed");
  });

  return NextResponse.json({ received: true });
}
```

**Key design decisions:**

1. **Deduplication**: In-memory `Set` with a cap of 1000 entries. GitHub retries on non-2xx, so duplicates are possible. The set evicts the oldest entry when full (FIFO approximation). For a single-server deployment, this is sufficient. If the server restarts, the set is empty, but webhook handlers should be idempotent anyway.

2. **Async processing**: The handler returns 200 immediately and processes the webhook in the background. GitHub has a 10-second timeout. Our handler just needs to validate the signature, check for duplicates, and dispatch -- all of which complete in <10ms. The actual deployment/build work happens asynchronously.

3. **Error isolation**: If `handleWebhook()` throws, the error is caught and logged. The 200 has already been sent, so GitHub won't retry (which is correct -- we already processed the event).

### Part B: Implement the Webhook Event Router

**File:** `packages/core/src/github/webhooks.ts`

```typescript
import type { Database } from "@gblockparty/shared/db";
import type { WebhookPayload } from "@gblockparty/shared/types";
import { createLogger } from "@gblockparty/shared/backend";
import { githubInstallations } from "@gblockparty/shared/db/schema";
import { eq } from "drizzle-orm";

const logger = createLogger("github-webhooks");

export interface WebhookContext {
  db: Database;
  payload: WebhookPayload;
  event: string;
  deliveryId: string;
}

export async function handleWebhook(ctx: WebhookContext): Promise<void> {
  const { event, payload, deliveryId, db } = ctx;

  logger.info({ event, deliveryId, action: payload.action }, "Processing webhook");

  switch (event) {
    case "push":
      await handlePush(ctx);
      break;
    case "pull_request":
      await handlePullRequest(ctx);
      break;
    case "installation":
      await handleInstallation(ctx);
      break;
    default:
      logger.debug({ event }, "Unhandled webhook event");
  }
}

// ── Push Event Handler ──────────────────────────────────────────

async function handlePush(ctx: WebhookContext): Promise<void> {
  const { payload, db } = ctx;

  if (!payload.repository || !payload.ref || !payload.after) {
    logger.warn("Push event missing required fields");
    return;
  }

  const repoFullName = payload.repository.full_name;
  const branch = payload.ref.replace("refs/heads/", "");
  const commitSha = payload.after;

  // Skip if this is a branch deletion (after is all zeros)
  if (commitSha === "0000000000000000000000000000000000000000") {
    logger.info({ repoFullName, branch }, "Branch deletion, skipping");
    return;
  }

  // Look up the project by repository name
  // TODO (Phase 4/5): Query projects table by githubRepoFullName
  // For now, log the intent
  logger.info(
    { repoFullName, branch, commitSha },
    "Push event: would trigger production deployment",
  );

  // TODO (Phase 4/5): When build system is ready:
  // 1. const project = await db.query.projects.findFirst({
  //      where: eq(projects.githubRepoFullName, repoFullName),
  //    });
  // 2. if (!project) return; // not a connected repo
  // 3. if (branch !== project.productionBranch) return; // not the production branch
  // 4. Create deployment record (status: 'queued')
  // 5. Set commit status to 'pending'
  // 6. Enqueue build job
}

// ── Pull Request Event Handler ──────────────────────────────────

async function handlePullRequest(ctx: WebhookContext): Promise<void> {
  const { payload, db } = ctx;

  if (!payload.pull_request || !payload.repository) {
    logger.warn("Pull request event missing required fields");
    return;
  }

  const action = payload.action;
  const prNumber = payload.pull_request.number;
  const repoFullName = payload.repository.full_name;
  const headSha = payload.pull_request.head.sha;
  const headRef = payload.pull_request.head.ref;

  switch (action) {
    case "opened":
    case "synchronize":
    case "reopened": {
      logger.info(
        { repoFullName, prNumber, headSha, headRef, action },
        "PR event: would trigger preview deployment",
      );

      // TODO (Phase 7): When preview system is ready:
      // 1. Look up project by repoFullName
      // 2. Create preview deployment record (type: 'preview', prNumber)
      // 3. Set commit status to 'pending'
      // 4. Enqueue preview build job
      break;
    }

    case "closed": {
      const merged = payload.pull_request.merged;
      logger.info(
        { repoFullName, prNumber, merged, action },
        "PR closed: would trigger preview cleanup",
      );

      // TODO (Phase 7): When preview system is ready:
      // 1. Look up active preview deployment for this PR
      // 2. Stop the preview container
      // 3. Release the port
      // 4. Remove Caddy route
      // 5. Update deployment status to 'archived'
      // 6. Delete preview Docker image
      break;
    }

    default:
      logger.debug({ action, prNumber }, "Unhandled PR action");
  }
}

// ── Installation Event Handler ──────────────────────────────────

async function handleInstallation(ctx: WebhookContext): Promise<void> {
  const { payload, db } = ctx;

  if (!payload.installation) {
    logger.warn("Installation event missing installation data");
    return;
  }

  const installationId = payload.installation.id;
  const accountLogin = payload.installation.account.login;
  const accountType = payload.installation.account.type;
  const action = payload.action;

  switch (action) {
    case "created": {
      logger.info(
        { installationId, accountLogin, accountType },
        "GitHub App installed",
      );

      await db
        .insert(githubInstallations)
        .values({
          id: installationId,
          githubAccountLogin: accountLogin,
          githubAccountType: accountType,
        })
        .onConflictDoUpdate({
          target: githubInstallations.id,
          set: {
            githubAccountLogin: accountLogin,
            githubAccountType: accountType,
          },
        });

      break;
    }

    case "deleted": {
      logger.info(
        { installationId, accountLogin },
        "GitHub App uninstalled",
      );

      await db
        .delete(githubInstallations)
        .where(eq(githubInstallations.id, installationId));

      break;
    }

    default:
      logger.debug({ action, installationId }, "Unhandled installation action");
  }
}
```

**Key design decisions:**

1. **Push handler is a placeholder**: The push handler logs intent but does not create deployments yet. The actual build queue and deployment creation require Phase 4 (build system) and Phase 5 (deployment engine). The handler structure is in place so those phases just need to uncomment and fill in the logic.

2. **PR handler is a placeholder**: Same situation. The routing and action dispatch is implemented, but the actual preview build/cleanup is Phase 7.

3. **Installation handler is fully implemented**: This is the one handler that can be completed now because it only touches the `github_installations` table, which exists from Phase 2. Uses `onConflictDoUpdate` for idempotency (re-processing the same installation event is safe).

4. **Drizzle ORM**: Uses the schema defined in `packages/shared/src/db/schema.ts` with the `githubInstallations` table.

### Part C: Implement Commit Status

**File:** `packages/core/src/github/commit-status.ts`

```typescript
import type { Octokit } from "@octokit/rest";
import { createLogger } from "@gblockparty/shared/backend";

const logger = createLogger("commit-status");

export type StatusState = "pending" | "success" | "failure" | "error";

export async function setCommitStatus(
  octokit: Octokit,
  owner: string,
  repo: string,
  sha: string,
  state: StatusState,
  options: {
    targetUrl?: string;
    description?: string;
    context?: string;
  } = {},
): Promise<void> {
  const {
    targetUrl,
    description,
    context = "gblockparty/deploy",
  } = options;

  logger.info(
    { owner, repo, sha: sha.substring(0, 7), state, context },
    "Setting commit status",
  );

  await octokit.repos.createCommitStatus({
    owner,
    repo,
    sha,
    state,
    target_url: targetUrl,
    description: truncate(description, 140), // GitHub limit is 140 chars
    context,
  });
}

function truncate(str: string | undefined, maxLen: number): string | undefined {
  if (!str) return str;
  if (str.length <= maxLen) return str;
  return str.substring(0, maxLen - 3) + "...";
}
```

**GitHub Commit Status API details:**
- Endpoint: `POST /repos/{owner}/{repo}/statuses/{sha}`
- `state`: one of `pending`, `success`, `failure`, `error`
- `target_url`: clickable link on the status check (link to deployment details page)
- `description`: max 140 characters, shown next to the status
- `context`: identifier for the status check (e.g., `gblockparty/deploy`). Multiple contexts can coexist.

### Part D: Implement PR Comment Create/Update

**File:** `packages/core/src/github/pr-commenter.ts`

```typescript
import type { Octokit } from "@octokit/rest";
import { createLogger } from "@gblockparty/shared/backend";

const logger = createLogger("pr-commenter");

const BOT_COMMENT_MARKER = "<!-- gblockparty-bot -->";

export async function createOrUpdatePRComment(
  octokit: Octokit,
  owner: string,
  repo: string,
  prNumber: number,
  body: string,
): Promise<void> {
  logger.info(
    { owner, repo, prNumber },
    "Creating or updating PR comment",
  );

  // Search for existing bot comment
  const existingComment = await findBotComment(octokit, owner, repo, prNumber);

  if (existingComment) {
    // Update existing comment
    await octokit.issues.updateComment({
      owner,
      repo,
      comment_id: existingComment.id,
      body,
    });
    logger.debug({ commentId: existingComment.id }, "Updated existing PR comment");
  } else {
    // Create new comment
    await octokit.issues.createComment({
      owner,
      repo,
      issue_number: prNumber,
      body,
    });
    logger.debug({ prNumber }, "Created new PR comment");
  }
}

async function findBotComment(
  octokit: Octokit,
  owner: string,
  repo: string,
  prNumber: number,
): Promise<{ id: number } | null> {
  // List comments on the PR, paginate through all
  const iterator = octokit.paginate.iterator(
    octokit.issues.listComments,
    {
      owner,
      repo,
      issue_number: prNumber,
      per_page: 100,
    },
  );

  for await (const { data: comments } of iterator) {
    for (const comment of comments) {
      if (comment.body?.includes(BOT_COMMENT_MARKER)) {
        return { id: comment.id };
      }
    }
  }

  return null;
}

export function formatDeploymentComment(
  status: string,
  url: string | null,
  buildDurationMs: number | null,
): string {
  const statusEmoji =
    status === "ready" ? "✅" : status === "failed" ? "❌" : "🔄";

  let comment = `${BOT_COMMENT_MARKER}\n`;
  comment += `## ${statusEmoji} Preview Deployment\n\n`;
  comment += `**Status:** ${status}\n`;
  if (url) {
    comment += `**URL:** ${url}\n`;
  }
  if (buildDurationMs) {
    comment += `**Build time:** ${(buildDurationMs / 1000).toFixed(1)}s\n`;
  }
  return comment;
}
```

**Bot comment strategy:**
- Every bot comment starts with `<!-- gblockparty-bot -->` (hidden HTML comment)
- When posting a comment, first search all existing comments on the PR for this marker
- If found, update that comment in-place (no duplicate comments)
- If not found, create a new comment
- Uses pagination to handle PRs with many comments
- PR comments use the Issues API (PRs are issues in GitHub's API)

