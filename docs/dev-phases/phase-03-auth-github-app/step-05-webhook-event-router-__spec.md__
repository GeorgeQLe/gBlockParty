## Testing

### Unit Tests for `handleWebhook`

```typescript
describe("handleWebhook", () => {
  describe("push events", () => {
    it("logs deployment intent for push to a known repo", async () => {
      const ctx = createMockContext("push", {
        ref: "refs/heads/main",
        after: "abc123",
        repository: { full_name: "user/repo", default_branch: "main", clone_url: "..." },
      });
      await handleWebhook(ctx);
      // Verify logger.info was called with production deployment message
    });

    it("skips branch deletions", async () => {
      const ctx = createMockContext("push", {
        ref: "refs/heads/feature",
        after: "0000000000000000000000000000000000000000",
        repository: { full_name: "user/repo", default_branch: "main", clone_url: "..." },
      });
      await handleWebhook(ctx);
      // Verify no deployment action
    });

    it("skips pushes with missing required fields", async () => {
      const ctx = createMockContext("push", {});
      await handleWebhook(ctx);
      // Verify warning logged, no crash
    });
  });

  describe("pull_request events", () => {
    it("logs preview intent for PR opened", async () => {
      const ctx = createMockContext("pull_request", {
        action: "opened",
        pull_request: { number: 42, head: { sha: "abc", ref: "feature" }, base: { ref: "main" }, merged: false },
        repository: { full_name: "user/repo", default_branch: "main", clone_url: "..." },
      });
      await handleWebhook(ctx);
      // Verify preview deployment message logged
    });

    it("logs cleanup intent for PR closed", async () => {
      const ctx = createMockContext("pull_request", {
        action: "closed",
        pull_request: { number: 42, head: { sha: "abc", ref: "feature" }, base: { ref: "main" }, merged: true },
        repository: { full_name: "user/repo", default_branch: "main", clone_url: "..." },
      });
      await handleWebhook(ctx);
      // Verify cleanup message logged
    });
  });

  describe("installation events", () => {
    it("inserts record on installation created", async () => {
      const ctx = createMockContext("installation", {
        action: "created",
        installation: { id: 99001, account: { login: "user", type: "User" } },
      });
      await handleWebhook(ctx);
      // Verify db.insert was called with correct data
    });

    it("deletes record on installation deleted", async () => {
      const ctx = createMockContext("installation", {
        action: "deleted",
        installation: { id: 99001, account: { login: "user", type: "User" } },
      });
      await handleWebhook(ctx);
      // Verify db.delete was called for the installation ID
    });

    it("handles duplicate installation created events idempotently", async () => {
      const ctx = createMockContext("installation", {
        action: "created",
        installation: { id: 99001, account: { login: "user", type: "User" } },
      });
      await handleWebhook(ctx);
      await handleWebhook(ctx); // second time
      // Verify no error, upsert works correctly
    });
  });
});
```

### Unit Tests for `setCommitStatus`

```typescript
describe("setCommitStatus", () => {
  it("calls octokit.repos.createCommitStatus with correct params", async () => {
    const octokit = createMockOctokit();
    await setCommitStatus(octokit, "owner", "repo", "abc123", "pending", {
      description: "Build in progress...",
      context: "gblockparty/deploy",
      targetUrl: "https://platform.example.dev/deployments/123",
    });
    expect(octokit.repos.createCommitStatus).toHaveBeenCalledWith({
      owner: "owner",
      repo: "repo",
      sha: "abc123",
      state: "pending",
      description: "Build in progress...",
      context: "gblockparty/deploy",
      target_url: "https://platform.example.dev/deployments/123",
    });
  });

  it("truncates descriptions longer than 140 characters", async () => {
    const octokit = createMockOctokit();
    const longDesc = "a".repeat(200);
    await setCommitStatus(octokit, "owner", "repo", "abc123", "failure", {
      description: longDesc,
    });
    const call = octokit.repos.createCommitStatus.mock.calls[0][0];
    expect(call.description.length).toBeLessThanOrEqual(140);
  });

  it("uses default context 'gblockparty/deploy' when none specified", async () => {
    const octokit = createMockOctokit();
    await setCommitStatus(octokit, "owner", "repo", "abc123", "success");
    const call = octokit.repos.createCommitStatus.mock.calls[0][0];
    expect(call.context).toBe("gblockparty/deploy");
  });
});
```

