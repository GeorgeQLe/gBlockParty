## Testing

### Unit Tests

```typescript
describe("GET /api/auth/me", () => {
  it("returns user data when session cookie is valid", async () => {
    // Set up: create a valid JWT and set it as the session cookie
    const token = await createSession({
      userId: "12345",
      githubLogin: "testuser",
      githubId: 12345,
    });
    // Mock cookies().get() to return the token
    const res = await GET();
    expect(res.status).toBe(200);
    const data = await res.json();
    expect(data).toEqual({
      userId: "12345",
      githubLogin: "testuser",
      githubId: 12345,
    });
  });

  it("returns 401 when no session cookie exists", async () => {
    // Mock cookies().get() to return undefined
    const res = await GET();
    expect(res.status).toBe(401);
    const data = await res.json();
    expect(data.error).toBe("Unauthorized");
  });

  it("returns 401 when JWT is expired", async () => {
    // Create a JWT with past expiration
    // Mock cookies to return it
    const res = await GET();
    expect(res.status).toBe(401);
  });

  it("returns 401 when JWT is malformed", async () => {
    // Mock cookies to return "not-a-jwt"
    const res = await GET();
    expect(res.status).toBe(401);
  });
});

describe("POST /api/auth/logout", () => {
  it("clears session cookie and returns ok", async () => {
    const res = await POST();
    expect(res.status).toBe(200);
    const data = await res.json();
    expect(data).toEqual({ ok: true });
    // Verify cookie was deleted
  });

  it("returns ok even when no session exists", async () => {
    const res = await POST();
    expect(res.status).toBe(200);
    const data = await res.json();
    expect(data).toEqual({ ok: true });
  });
});

describe("withAuth middleware", () => {
  it("passes session to handler when authenticated", async () => {
    const handler = vi.fn().mockResolvedValue(NextResponse.json({ ok: true }));
    const wrapped = withAuth(handler);
    // Mock valid session
    await wrapped(mockRequest, mockContext);
    expect(handler).toHaveBeenCalledWith(
      mockRequest,
      expect.objectContaining({ userId: "12345" }),
      mockContext,
    );
  });

  it("returns 401 without calling handler when not authenticated", async () => {
    const handler = vi.fn();
    const wrapped = withAuth(handler);
    // Mock no session
    const res = await wrapped(mockRequest, mockContext);
    expect(res.status).toBe(401);
    expect(handler).not.toHaveBeenCalled();
  });
});
```

### Manual Verification

1. After completing Step 2 (OAuth login), visit `/api/auth/me` in the browser
2. Verify the JSON response contains correct user data
3. Call `POST /api/auth/logout` (can use curl or browser console)
4. Verify `/api/auth/me` now returns 401
5. Verify the `gblockparty-session` cookie is gone from browser dev tools
