## Implementation

### File: `packages/core/src/deploy/rollback.ts`

Replace the existing TODO stub:

```typescript
import type { Database } from "@gblockparty/shared/db";
import { createLogger } from "@gblockparty/shared/backend";
import { deployments, projects } from "@gblockparty/shared/db";
import { eq, and, desc } from "drizzle-orm";
import { createDockerClient, runContainer, stopContainer } from "../providers/docker/client";
import { allocatePort, releasePort } from "./port-allocator";
import { updateCaddyRoute } from "../caddy/config"; // Caddy config module
import { HEALTH_CHECK } from "@gblockparty/shared/constants";

const logger = createLogger("rollback");

export async function rollbackDeployment(
  db: Database,
  projectId: string,
  targetDeploymentId: string,
): Promise<string> {
  logger.info({ projectId, targetDeploymentId }, "Rollback initiated");

  // 1. Fetch the target deployment (the one we're rolling back TO)
  const targetDeployment = await db.query.deployments.findFirst({
    where: and(
      eq(deployments.id, targetDeploymentId),
      eq(deployments.projectId, projectId),
    ),
  });

  if (!targetDeployment) {
    throw new Error(`Target deployment ${targetDeploymentId} not found`);
  }

  if (!targetDeployment.dockerImageTag) {
    throw new Error(`Target deployment ${targetDeploymentId} has no Docker image tag`);
  }

  // 2. Validate the Docker image still exists
  const docker = createDockerClient();
  const imageExists = await checkImageExists(docker, targetDeployment.dockerImageTag);
  if (!imageExists) {
    throw new Error(
      `Docker image ${targetDeployment.dockerImageTag} has been pruned and is no longer available`,
    );
  }

  // 3. Fetch the project and current production deployment
  const project = await db.query.projects.findFirst({
    where: eq(projects.id, projectId),
  });

  if (!project) {
    throw new Error(`Project ${projectId} not found`);
  }

  // 4. Create new deployment record (type: rollback)
  const [newDeployment] = await db
    .insert(deployments)
    .values({
      projectId,
      type: "rollback",
      status: "deploying",
      commitSha: targetDeployment.commitSha,
      branch: targetDeployment.branch,
      dockerImageTag: targetDeployment.dockerImageTag,
      sourceDeploymentId: targetDeploymentId,
    })
    .returning();

  try {
    // 5. Allocate port
    const port = await allocatePort(db, newDeployment.id, "production");

    // 6. Start container from target image
    const containerId = await runContainer(
      docker,
      targetDeployment.dockerImageTag,
      `${project.slug}-${newDeployment.id.slice(0, 8)}`,
      port,
      {}, // Env vars loaded from project config
    );

    // 7. Health check
    const healthCheckPath = project.healthCheckPath ?? HEALTH_CHECK.DEFAULT_PATH;
    await performHealthCheck(port, healthCheckPath);

    // 8. Update Caddy routing
    const hostname = `${project.slug}.${process.env.PLATFORM_DOMAIN}`;
    await updateCaddyRoute(hostname, port);

    // 9. Stop current production container
    if (project.productionDeploymentId) {
      const currentDeployment = await db.query.deployments.findFirst({
        where: eq(deployments.id, project.productionDeploymentId),
      });
      if (currentDeployment?.containerId) {
        await stopContainer(docker, currentDeployment.containerId);
      }
      // Release old port
      if (currentDeployment?.port) {
        await releasePort(db, currentDeployment.port);
      }
      // Archive old deployment
      await db
        .update(deployments)
        .set({ status: "archived" })
        .where(eq(deployments.id, project.productionDeploymentId));
    }

    // 10. Update deployment record and project
    await db
      .update(deployments)
      .set({
        status: "ready",
        containerId,
        port,
        url: `https://${hostname}`,
        updatedAt: new Date(),
      })
      .where(eq(deployments.id, newDeployment.id));

    await db
      .update(projects)
      .set({
        productionDeploymentId: newDeployment.id,
        updatedAt: new Date(),
      })
      .where(eq(projects.id, projectId));

    logger.info(
      { projectId, newDeploymentId: newDeployment.id, targetDeploymentId },
      "Rollback complete",
    );

    return newDeployment.id;
  } catch (error) {
    // Rollback the rollback -- mark as failed
    await db
      .update(deployments)
      .set({
        status: "failed",
        errorMessage: error instanceof Error ? error.message : "Unknown error",
        updatedAt: new Date(),
      })
      .where(eq(deployments.id, newDeployment.id));

    logger.error(
      { projectId, targetDeploymentId, error },
      "Rollback failed",
    );

    throw error;
  }
}
```

### Health Check

The health check function retries an HTTP GET request to the container's health endpoint:

```typescript
async function performHealthCheck(port: number, path: string): Promise<void> {
  const url = `http://localhost:${port}${path}`;

  for (let attempt = 1; attempt <= HEALTH_CHECK.MAX_RETRIES; attempt++) {
    try {
      const response = await fetch(url);
      if (response.ok) {
        logger.info({ port, path, attempt }, "Health check passed");
        return;
      }
      logger.warn({ port, path, attempt, status: response.status }, "Health check failed");
    } catch (error) {
      logger.warn({ port, path, attempt, error }, "Health check connection failed");
    }

    if (attempt < HEALTH_CHECK.MAX_RETRIES) {
      await new Promise((resolve) => setTimeout(resolve, HEALTH_CHECK.RETRY_INTERVAL_MS));
    }
  }

  throw new Error(
    `Health check failed after ${HEALTH_CHECK.MAX_RETRIES} attempts on ${url}`,
  );
}
```

Uses constants from `HEALTH_CHECK`:
- `MAX_RETRIES`: 10 attempts
- `RETRY_INTERVAL_MS`: 2000ms between attempts

Total max wait: 10 * 2s = 20 seconds for the container to become healthy.

### Image Existence Check

Before starting the rollback, verify the Docker image has not been pruned:

```typescript
async function checkImageExists(docker: Dockerode, imageTag: string): Promise<boolean> {
  try {
    const image = docker.getImage(imageTag);
    await image.inspect();
    return true;
  } catch (error) {
    if (error instanceof Error && error.message.includes("404")) {
      return false;
    }
    throw error;
  }
}
```

