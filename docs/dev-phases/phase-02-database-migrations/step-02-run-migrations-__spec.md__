## CRUD Verification Tests

Run these SQL statements to verify each table accepts and returns data correctly.

### Test 1: `projects` table

```sql
-- INSERT
INSERT INTO projects (name, slug, production_branch)
VALUES ('Test App', 'test-app', 'main')
RETURNING id, name, slug, created_at;

-- SELECT
SELECT * FROM projects WHERE slug = 'test-app';

-- UPDATE
UPDATE projects SET framework = 'nextjs', next_mode = 'server'
WHERE slug = 'test-app'
RETURNING id, framework, next_mode, updated_at;

-- Verify UNIQUE constraint (should fail)
INSERT INTO projects (name, slug) VALUES ('Duplicate', 'test-app');
-- Expected: ERROR: duplicate key value violates unique constraint "projects_slug_unique"
```

### Test 2: `deployments` table with FK cascade

```sql
-- INSERT (using the project id from Test 1)
INSERT INTO deployments (project_id, type, status, commit_sha, branch)
VALUES (
  (SELECT id FROM projects WHERE slug = 'test-app'),
  'production', 'queued', 'abc1234', 'main'
)
RETURNING id, project_id, type, status;

-- SELECT
SELECT d.id, d.type, d.status, p.name AS project_name
FROM deployments d
JOIN projects p ON p.id = d.project_id
WHERE p.slug = 'test-app';

-- UPDATE
UPDATE deployments SET status = 'building'
WHERE project_id = (SELECT id FROM projects WHERE slug = 'test-app')
RETURNING id, status, updated_at;
```

### Test 3: `env_vars` with unique composite constraint

```sql
-- INSERT
INSERT INTO env_vars (project_id, scope, key, value, is_secret)
VALUES (
  (SELECT id FROM projects WHERE slug = 'test-app'),
  'production', 'API_KEY', 'test-value', true
)
RETURNING id, scope, key, is_secret;

-- Verify composite unique constraint (should fail)
INSERT INTO env_vars (project_id, scope, key, value)
VALUES (
  (SELECT id FROM projects WHERE slug = 'test-app'),
  'production', 'API_KEY', 'different-value'
);
-- Expected: ERROR: duplicate key value violates unique constraint "env_vars_project_scope_key"

-- Same key in different scope should succeed
INSERT INTO env_vars (project_id, scope, key, value)
VALUES (
  (SELECT id FROM projects WHERE slug = 'test-app'),
  'preview', 'API_KEY', 'preview-value'
)
RETURNING id, scope, key;
```

### Test 4: `managed_databases`

```sql
INSERT INTO managed_databases (project_id, db_name, db_user, db_password_encrypted)
VALUES (
  (SELECT id FROM projects WHERE slug = 'test-app'),
  'app_test_app', 'app_test_app_user', 'encrypted_password_here'
)
RETURNING id, db_name, size_bytes;

-- Verify size_bytes default is 0
SELECT size_bytes FROM managed_databases WHERE db_name = 'app_test_app';
```

### Test 5: `github_installations`

```sql
INSERT INTO github_installations (id, github_account_login, github_account_type)
VALUES (12345678, 'george-dev', 'User')
RETURNING id, github_account_login, created_at;
```

### Test 6: `port_allocations`

```sql
INSERT INTO port_allocations (port, deployment_id)
VALUES (
  3001,
  (SELECT id FROM deployments LIMIT 1)
)
RETURNING port, deployment_id, allocated_at;
```

### Test 7: `notification_settings`

```sql
INSERT INTO notification_settings (slack_webhook_url, notify_on_failure)
VALUES ('https://hooks.slack.com/services/T00/B00/xxx', true)
RETURNING id, notify_on_failure, notify_on_rollback;

-- Verify defaults
SELECT notify_on_failure, notify_on_rollback FROM notification_settings;
-- Expected: true, true
```

### Test 8: CASCADE delete

```sql
-- Verify cascade: deleting a project should delete its deployments, env_vars, managed_databases
-- Count before delete
SELECT
  (SELECT COUNT(*) FROM deployments WHERE project_id = (SELECT id FROM projects WHERE slug = 'test-app')) AS deployments_count,
  (SELECT COUNT(*) FROM env_vars WHERE project_id = (SELECT id FROM projects WHERE slug = 'test-app')) AS env_vars_count,
  (SELECT COUNT(*) FROM managed_databases WHERE project_id = (SELECT id FROM projects WHERE slug = 'test-app')) AS databases_count;

-- Delete project
DELETE FROM projects WHERE slug = 'test-app';

-- Count after delete (all should be 0)
SELECT
  (SELECT COUNT(*) FROM deployments) AS deployments_count,
  (SELECT COUNT(*) FROM env_vars) AS env_vars_count,
  (SELECT COUNT(*) FROM managed_databases) AS databases_count;
```

### Cleanup

After all tests, clean up any remaining test data:

```sql
DELETE FROM notification_settings;
DELETE FROM github_installations WHERE id = 12345678;
-- port_allocations cascade-deleted with deployment, which cascade-deleted with project
```

