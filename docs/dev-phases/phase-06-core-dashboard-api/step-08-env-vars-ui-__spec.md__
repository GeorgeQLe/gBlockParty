## Implementation Details

### Page: `apps/dashboard/src/app/projects/[id]/environment/page.tsx`

Convert to a client component with SWR data fetching. The page manages the scope toggle state and coordinates all CRUD operations.

```typescript
"use client";

import { useParams } from "next/navigation";
import { useState } from "react";
import useSWR from "swr";
import { fetcher } from "@/lib/swr";
import { ScopeToggle } from "@/components/env/scope-toggle";
import { EnvVarList } from "@/components/env/env-var-list";
import { AddEnvVarForm } from "@/components/env/add-env-var-form";
import { BulkEditMode } from "@/components/env/bulk-edit-mode";

export default function EnvironmentPage() {
  const params = useParams();
  const projectId = params.id as string;
  const [scope, setScope] = useState<"production" | "preview">("production");
  const [isBulkEdit, setIsBulkEdit] = useState(false);

  const { data: envVars, error, isLoading, mutate } = useSWR(
    `/api/projects/${projectId}/env?scope=${scope}`,
    fetcher,
  );

  // ... render components
}
```

#### Page Layout

```
+------------------------------------------------------------------+
| Environment Variables                                              |
|                                                                    |
| [Production] [Preview]        [ Bulk Edit ]                      |
|                                                                    |
+------------------------------------------------------------------+
| Add Variable                                                       |
|                                                                    |
| Key:    [________________]                                        |
| Value:  [________________]  [ ] Secret                            |
|                              [ Add Variable ]                     |
+------------------------------------------------------------------+
| Variables                                                          |
|                                                                    |
| DATABASE_URL        ***                      [Edit] [Delete]      |
| NEXT_PUBLIC_API_URL https://api.example.com  [Edit] [Delete]      |
| NODE_ENV            production               [Edit] [Delete]      |
| SECRET_KEY          ***                      [Edit] [Delete]      |
|                                                                    |
+------------------------------------------------------------------+
```

