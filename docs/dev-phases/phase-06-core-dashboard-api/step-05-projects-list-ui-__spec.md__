## Implementation Details

### Page: `apps/dashboard/src/app/page.tsx`

Convert from a server component to a client component (needed for SWR). The page is the entry point that composes the header, connect button, and projects grid.

```typescript
"use client";

import useSWR from "swr";
import { ProjectCard } from "@/components/projects/project-card";
import { ProjectsEmptyState } from "@/components/projects/projects-empty-state";
import { ProjectsLoadingSkeleton } from "@/components/projects/projects-loading-skeleton";

const fetcher = (url: string) => fetch(url).then((res) => res.json());

export default function HomePage() {
  const { data: projects, error, isLoading } = useSWR("/api/projects", fetcher);

  return (
    <div>
      {/* Header with title and Connect Repo button */}
      <div className="mb-8 flex items-center justify-between">
        <h2 className="text-2xl font-bold text-gray-900">Projects</h2>
        <a
          href={process.env.NEXT_PUBLIC_GITHUB_APP_INSTALL_URL ?? "#"}
          className="rounded-md bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-700"
        >
          Connect Repo
        </a>
      </div>

      {/* Content: loading, error, empty, or grid */}
      {isLoading && <ProjectsLoadingSkeleton />}
      {error && <ErrorBanner message="Failed to load projects" />}
      {!isLoading && !error && projects?.length === 0 && <ProjectsEmptyState />}
      {!isLoading && !error && projects?.length > 0 && (
        <div className="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {projects.map((project) => (
            <ProjectCard key={project.id} project={project} />
          ))}
        </div>
      )}
    </div>
  );
}
```

### SWR Configuration

Create a shared SWR fetcher and provider. Add an `SWRConfig` provider in the root layout or create a client layout wrapper.

**File: `apps/dashboard/src/lib/swr.ts`**

```typescript
export const fetcher = async (url: string) => {
  const res = await fetch(url);
  if (!res.ok) {
    const error = new Error("API request failed");
    (error as any).status = res.status;
    (error as any).info = await res.json().catch(() => null);
    throw error;
  }
  return res.json();
};
```

