## Implementation Requirements

### `DeployOptions` Interface Update

Expand the `DeployOptions` interface to include all necessary context:

```typescript
export interface DeployOptions {
  db: Database;
  projectId: string;
  deploymentId: string;
  imageTag: string;
  healthCheckPath: string;
  type: "production" | "preview";       // determines port range
  projectSlug: string;                  // for URL generation
  prNumber?: number;                    // for preview URL generation
  previousContainerId?: string;         // container to stop after successful deploy
  previousPort?: number;                // port to release after successful deploy
  domain?: string;                      // platform domain for URL generation
}
```

Note: `envVars` is removed from the options. The Deployer retrieves env vars itself using `getEnvVars()` from Step 4, based on the `projectId` and deployment `type` (which maps to scope).

### `Deployer.deploy()` Implementation

```typescript
async deploy(): Promise<{ containerId: string; port: number; url: string }> {
  const {
    db, projectId, deploymentId, imageTag, healthCheckPath,
    type, projectSlug, prNumber, previousContainerId, previousPort, domain,
  } = this.options;

  const portAllocator = new PortAllocator(db);
  const caddy = new CaddyClient();
  const docker = createDockerClient();

  let allocatedPort: number | null = null;
  let envFilePath = "";
  let newContainerId: string | null = null;

  try {
    // --- Step 1: Allocate port ---
    logger.info({ deploymentId, type }, "Allocating port");
    allocatedPort = await portAllocator.allocate(deploymentId, type);
    logger.info({ deploymentId, port: allocatedPort }, "Port allocated");

    // --- Step 2: Get env vars ---
    const scope = type === "preview" ? "preview" : "production";
    const envVars = await getEnvVars(db, projectId, scope);
    logger.info(
      { deploymentId, envVarCount: Object.keys(envVars).length },
      "Environment variables retrieved"
    );

    // --- Step 3: Write temp env file ---
    envFilePath = await writeEnvFile(envVars, deploymentId);

    // --- Step 4: Start container ---
    const containerName = `${projectSlug}-${deploymentId.slice(0, 8)}`;
    logger.info(
      { deploymentId, imageTag, port: allocatedPort, containerName },
      "Starting container"
    );
    newContainerId = await runContainer(
      docker, imageTag, containerName, allocatedPort, envVars,
    );
    logger.info(
      { deploymentId, containerId: newContainerId },
      "Container started"
    );

    // --- Step 5: Health check ---
    logger.info(
      { deploymentId, containerId: newContainerId, healthCheckPath },
      "Running health check"
    );
    const healthy = await waitForHealthy(
      docker, newContainerId, healthCheckPath, allocatedPort,
    );

    if (!healthy) {
      throw new Error(
        `Health check failed for container ${newContainerId} on port ${allocatedPort}`
      );
    }
    logger.info({ deploymentId }, "Health check passed");

    // --- Step 6: Update Caddy routing ---
    const hostname = type === "preview" && prNumber
      ? `pr-${prNumber}--${projectSlug}.${domain ?? process.env.PLATFORM_DOMAIN}`
      : `${projectSlug}.${domain ?? process.env.PLATFORM_DOMAIN}`;

    logger.info(
      { deploymentId, hostname, port: allocatedPort },
      "Updating Caddy routing"
    );
    await caddy.addRoute(hostname, allocatedPort);

    // --- Step 7: Stop old container (best effort) ---
    if (previousContainerId) {
      try {
        logger.info(
          { deploymentId, previousContainerId },
          "Stopping old container"
        );
        await stopContainer(docker, previousContainerId, 30);
      } catch (error) {
        logger.warn(
          { previousContainerId, error: (error as Error).message },
          "Failed to stop old container (continuing)"
        );
      }
    }

    // --- Step 8: Release old port (best effort) ---
    if (previousPort) {
      try {
        await portAllocator.release(previousPort);
      } catch (error) {
        logger.warn(
          { previousPort, error: (error as Error).message },
          "Failed to release old port (continuing)"
        );
      }
    }

    // --- Step 9: Generate URL ---
    const url = type === "preview" && prNumber
      ? generatePreviewUrl(projectSlug, prNumber, domain)
      : generateUrl(projectSlug, domain);

    // --- Step 10: Update deployment record ---
    await db.update(deployments)
      .set({
        status: "ready",
        containerId: newContainerId,
        port: allocatedPort,
        url,
        updatedAt: new Date(),
      })
      .where(eq(deployments.id, deploymentId));

    // --- Step 11: Update project's production deployment ---
    if (type === "production") {
      await db.update(projects)
        .set({
          productionDeploymentId: deploymentId,
          updatedAt: new Date(),
        })
        .where(eq(projects.id, projectId));
    }

    logger.info(
      { deploymentId, containerId: newContainerId, port: allocatedPort, url },
      "Deployment successful"
    );

    return { containerId: newContainerId, port: allocatedPort, url };

  } catch (error) {
    // --- Rollback on failure ---
    logger.error(
      { deploymentId, error: (error as Error).message },
      "Deployment failed, rolling back"
    );

    // Stop new container if started
    if (newContainerId) {
      try {
        await stopContainer(docker, newContainerId, 10);
      } catch (e) {
        logger.warn({ containerId: newContainerId }, "Failed to stop new container during rollback");
      }
    }

    // Release allocated port
    if (allocatedPort) {
      try {
        await portAllocator.release(allocatedPort);
      } catch (e) {
        logger.warn({ port: allocatedPort }, "Failed to release port during rollback");
      }
    }

    // Update deployment record to failed
    await db.update(deployments)
      .set({
        status: "failed",
        errorMessage: (error as Error).message,
        updatedAt: new Date(),
      })
      .where(eq(deployments.id, deploymentId));

    throw error;

  } finally {
    // --- Cleanup env file (always) ---
    await cleanupEnvFile(envFilePath);
  }
}
```

### `rollbackDeployment()` Implementation

```typescript
export async function rollbackDeployment(
  db: Database,
  projectId: string,
  targetDeploymentId: string,
): Promise<string> {
  logger.info({ projectId, targetDeploymentId }, "Rollback initiated");

  // 1. Get the target deployment's image tag
  const [targetDeployment] = await db.select()
    .from(deployments)
    .where(eq(deployments.id, targetDeploymentId));

  if (!targetDeployment) {
    throw new Error(`Target deployment ${targetDeploymentId} not found`);
  }

  if (!targetDeployment.dockerImageTag) {
    throw new Error(`Target deployment ${targetDeploymentId} has no Docker image tag`);
  }

  // 2. Get the project (for slug and current deployment)
  const [project] = await db.select()
    .from(projects)
    .where(eq(projects.id, projectId));

  if (!project) {
    throw new Error(`Project ${projectId} not found`);
  }

  // 3. Get current production deployment (to stop its container)
  let previousContainerId: string | undefined;
  let previousPort: number | undefined;
  if (project.productionDeploymentId) {
    const [currentDeployment] = await db.select()
      .from(deployments)
      .where(eq(deployments.id, project.productionDeploymentId));

    if (currentDeployment) {
      previousContainerId = currentDeployment.containerId ?? undefined;
      previousPort = currentDeployment.port ?? undefined;
    }
  }

  // 4. Create new deployment record
  const [newDeployment] = await db.insert(deployments)
    .values({
      projectId,
      type: "rollback",
      status: "deploying",
      commitSha: targetDeployment.commitSha,
      branch: targetDeployment.branch,
      dockerImageTag: targetDeployment.dockerImageTag,
      sourceDeploymentId: targetDeploymentId,
    })
    .returning();

  // 5. Run the deploy pipeline with the old image
  const deployer = new Deployer({
    db,
    projectId,
    deploymentId: newDeployment.id,
    imageTag: targetDeployment.dockerImageTag,
    healthCheckPath: HEALTH_CHECK.DEFAULT_PATH,
    type: "production",
    projectSlug: project.slug,
    previousContainerId,
    previousPort,
  });

  await deployer.deploy();

  logger.info(
    { projectId, targetDeploymentId, newDeploymentId: newDeployment.id },
    "Rollback completed"
  );

  return newDeployment.id;
}
```

---

## Container Naming Convention

Container names follow the pattern `{projectSlug}-{deploymentIdPrefix}`:

| Deployment | Container Name |
|------------|---------------|
| Production `myapp`, deployment `a1b2c3d4-...` | `myapp-a1b2c3d4` |
| Preview `myapp` PR #42, deployment `e5f6g7h8-...` | `myapp-e5f6g7h8` |
| Rollback `myapp`, deployment `i9j0k1l2-...` | `myapp-i9j0k1l2` |

The 8-character prefix of the deployment UUID is sufficient for uniqueness within the platform's scale.

---

## Failure Rollback Matrix

| Failed Step | Port | Container | Caddy | Env File | Deployment Record |
|-------------|------|-----------|-------|----------|-------------------|
| 1. Port allocation | N/A | N/A | N/A | N/A | Set FAILED |
| 2. Get env vars | Release | N/A | N/A | N/A | Set FAILED |
| 3. Write env file | Release | N/A | N/A | Cleanup | Set FAILED |
| 4. Start container | Release | N/A | N/A | Cleanup | Set FAILED |
| 5. Health check | Release | Stop new | N/A | Cleanup | Set FAILED |
| 6. Caddy update | Release | Stop new | N/A | Cleanup | Set FAILED |
| 7. Stop old container | Keep new | Keep new | Keep new | Cleanup | Set READY (best effort) |
| 8. Release old port | Keep new | Keep new | Keep new | Cleanup | Set READY (best effort) |
| 9. DB update | Keep new | Keep new | Keep new | Cleanup | Orphaned (log error) |

Steps 7 and 8 (stop old container, release old port) are "best effort" -- failures here do not roll back the new deployment because it is already healthy and routing traffic.

