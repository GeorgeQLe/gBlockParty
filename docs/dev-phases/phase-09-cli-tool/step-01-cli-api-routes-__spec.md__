### 2. `apps/dashboard/src/app/api/cli/env/[projectId]/route.ts`

**Current state:** GET returns empty `{}`, POST returns 501.

**Target implementation:**

```typescript
import { NextRequest } from "next/server";
import { withAuth, jsonResponse, errorResponse } from "@/lib/api-helpers";
import { db } from "@gblockparty/shared/db";
import { envVars, projects } from "@gblockparty/shared/db/schema";
import { eq, and } from "drizzle-orm";

// GET: Download env vars for CLI (env pull)
export const GET = withAuth(async (request, _session, context) => {
  const { projectId } = await context.params;
  const { searchParams } = new URL(request.url);
  const scope = searchParams.get("scope") ?? "production";

  // Validate scope
  if (scope !== "production" && scope !== "preview") {
    return errorResponse('scope must be "production" or "preview"', 400);
  }

  // Verify project exists
  const project = await db.query.projects.findFirst({
    where: eq(projects.id, projectId),
  });

  if (!project) {
    return errorResponse("Project not found", 404);
  }

  // Fetch env vars for project and scope
  const vars = await db.query.envVars.findMany({
    where: and(
      eq(envVars.projectId, projectId),
      eq(envVars.scope, scope)
    ),
  });

  // Mask secret values
  const maskedVars = vars.map((v) => ({
    key: v.key,
    value: v.isSecret ? "***" : v.value,
    isSecret: v.isSecret,
  }));

  return jsonResponse({
    projectId,
    scope,
    vars: maskedVars,
  });
});

// POST: Upload env vars from CLI (env push)
export const POST = withAuth(async (request, _session, context) => {
  const { projectId } = await context.params;
  const body = await request.json();
  const { scope, vars } = body;

  // Validate inputs
  if (!scope || (scope !== "production" && scope !== "preview")) {
    return errorResponse('scope must be "production" or "preview"', 400);
  }

  if (!Array.isArray(vars) || vars.length === 0) {
    return errorResponse("vars must be a non-empty array of { key, value } objects", 400);
  }

  // Verify project exists
  const project = await db.query.projects.findFirst({
    where: eq(projects.id, projectId),
  });

  if (!project) {
    return errorResponse("Project not found", 404);
  }

  // Upsert each env var
  let updated = 0;
  for (const { key, value } of vars) {
    if (!key || typeof key !== "string") continue;

    await db
      .insert(envVars)
      .values({
        projectId,
        scope,
        key,
        value: value ?? "",
        isSecret: false,
      })
      .onConflictDoUpdate({
        target: [envVars.projectId, envVars.scope, envVars.key],
        set: {
          value: value ?? "",
          updatedAt: new Date(),
        },
      });

    updated++;
  }

  return jsonResponse({
    projectId,
    scope,
    updated,
  });
});
```

**GET `/api/cli/env/:projectId`**

Query parameters:
- `scope` (optional, default `"production"`): `"production"` or `"preview"`

Response:
```typescript
{
  projectId: string;
  scope: string;
  vars: Array<{
    key: string;
    value: string;        // "***" for secrets
    isSecret: boolean;
  }>;
}
```

**POST `/api/cli/env/:projectId`**

Request body:
```typescript
{
  scope: string;           // "production" or "preview"
  vars: Array<{
    key: string;
    value: string;
  }>;
}
```

Response:
```typescript
{
  projectId: string;
  scope: string;
  updated: number;         // Count of vars upserted
}
```

---

## Auth Token Validation

The `withAuth` middleware already handles Bearer token extraction from the `Authorization` header. The flow is:

1. Check for `Authorization: Bearer {token}` header
2. If present, validate the token (verify JWT signature or validate against stored token)
3. If valid, attach the session to the request and continue
4. If invalid or missing, return `errorResponse("Unauthorized", 401)`

No changes to `withAuth` are needed. The CLI API routes simply wrap their handlers with `withAuth()` like all other protected routes.

